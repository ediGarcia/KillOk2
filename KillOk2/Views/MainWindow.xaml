<Window x:Class="KillOk2.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:KillOk2.ViewModels"
        mc:Ignorable="d"
        Title="Kill OK 2.0" Height="500" Width="800"
        Background="#F4F4F4"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance viewModels:MainViewModel}">

    <Grid
        Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition
                Height="Auto" />
            <RowDefinition />
            <RowDefinition
                Height="Auto" />
        </Grid.RowDefinitions>

        <Button
            Grid.Row="0"
            Command="{Binding ToggleMonitoringCommand}">
            <Grid>
                <Grid.Resources>
                    <SolidColorBrush x:Key="IdleBrush">
                        LightGray
                    </SolidColorBrush>

                    <SolidColorBrush x:Key="RunningBrush">
                        GreenYellow
                    </SolidColorBrush>
                </Grid.Resources>
                <Grid.Triggers>
                    <EventTrigger
                        RoutedEvent="Grid.Loaded">
                        <BeginStoryboard>
                            <Storyboard
                                TargetName="ElpState">
                                <DoubleAnimation
                                    DecelerationRatio="1"
                                    Duration="00:00:00.500"
                                    RepeatBehavior="Forever"
                                    To="14"
                                    Storyboard.TargetProperty="Height" />
                                <DoubleAnimation
                                    DecelerationRatio="1"
                                    Duration="00:00:00.500"
                                    RepeatBehavior="Forever"
                                    To="14"
                                    Storyboard.TargetProperty="Width" />
                                <DoubleAnimation
                                    DecelerationRatio="1"
                                    Duration="00:00:00.500"
                                    RepeatBehavior="Forever"
                                    To="0"
                                    Storyboard.TargetProperty="Opacity" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Grid.Triggers>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition
                        Width="14"/>
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    HorizontalAlignment="Right"
                    Margin="0, 0, 2, 0">
                    <TextBlock.Style>
                        <Style
                            TargetType="TextBlock"
                            BasedOn="{StaticResource {x:Type TextBlock}}">
                            <Setter
                                Property="Text"
                                Value="Idle" />

                            <Style.Triggers>
                                <DataTrigger
                                    Binding="{Binding IsRunning}"
                                    Value="True">
                                    <Setter
                                        Property="Text"
                                        Value="Running" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Ellipse
                    x:Name="ElpState"
                    Grid.Column="1"
                    Fill="{StaticResource RunningBrush}"
                    Height="7"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Width="7" />
                <Ellipse
                    Grid.Column="1"
                    VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style
                            TargetType="Ellipse">
                            <Setter
                                Property="Fill"
                                Value="{StaticResource IdleBrush}" />
                            <Setter
                                Property="Height"
                                Value="7" />
                            <Setter
                                Property="Width"
                                Value="7" />

                            <Style.Triggers>
                                <DataTrigger
                                    Binding="{Binding IsRunning}"
                                    Value="True">
                                    <Setter
                                        Property="Fill"
                                        Value="{StaticResource RunningBrush}" />
                                    <Setter
                                        Property="Height"
                                        Value="7" />
                                    <Setter
                                        Property="Width"
                                        Value="7" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
            </Grid>
        </Button>

        <Border
            Grid.Row="1"
            Background="White"
            Margin="0, 10">
            <Border.Style>
                <Style
                    TargetType="Border">
                    <Setter
                        Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect
                                Direction="-45"
                                Opacity=".5"
                                ShadowDepth="3" />
                        </Setter.Value>
                    </Setter>

                    <Style.Triggers>
                        <Trigger
                            Property="IsMouseOver"
                            Value="True">
                            <Setter
                                Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect
                                        Direction="-45"
                                        Opacity=".5"
                                        ShadowDepth="4" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.OpacityMask>
                <VisualBrush>
                    <VisualBrush.Visual>
                        <Border
                            Background="Black"
                            CornerRadius="{StaticResource DefaultCornerRadius}"
                            Height="500"
                            Width="500"/>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Border.OpacityMask>
            <ScrollViewer
                x:Name="ScvClosedDialogs"
                HorizontalScrollBarVisibility="Disabled">
                <ItemsControl
                    Background="Transparent"
                    ItemsSource="{Binding ClosedDialogs}">
                    <ItemsControl.ContextMenu>
                        <ContextMenu>
                            <MenuItem
                                Command="{Binding ClearDialogsCommand}"
                                Header="Clear list" />
                            <MenuItem
                                Header="Auto-scroll"
                                IsCheckable="True"
                                IsChecked="{Binding AutoScroll}" />
                        </ContextMenu>
                    </ItemsControl.ContextMenu>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate
                            DataType="{x:Type viewModels:DialogInfoViewModel}">
                            <DataTemplate.Resources>
                                <Style
                                    TargetType="TextBlock">
                                    <Setter
                                        Property="TextWrapping"
                                        Value="Wrap" />
                                    <Setter
                                        Property="VerticalAlignment"
                                        Value="Center" />
                                </Style>
                            </DataTemplate.Resources>

                            <Border
                                CornerRadius="{StaticResource DefaultCornerRadius}"
                                Margin="10, 10, 10, 0"
                                Padding=" 10, 5"
                                UseLayoutRounding="True">
                                <Border.Style>
                                    <Style
                                        TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger
                                                Binding="{Binding Type}"
                                                Value="Information">
                                                <Setter
                                                    Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush
                                                            EndPoint="1, .5"
                                                            StartPoint="0, .5">
                                                            <GradientStop
                                                                Color="#E8F5FA"
                                                                Offset=".3" />
                                                            <GradientStop
                                                                Color="White"
                                                                Offset=".9" />
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>

                                            <DataTrigger
                                                Binding="{Binding Type}"
                                                Value="Warning">
                                                <Setter
                                                    Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush
                                                            EndPoint="1, .5"
                                                            StartPoint="0, .5">
                                                            <GradientStop
                                                                Color="#FAF9E8"
                                                                Offset=".3" />
                                                            <GradientStop
                                                                Color="White"
                                                                Offset=".9" />
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>

                                            <DataTrigger
                                                Binding="{Binding Type}"
                                                Value="Error">
                                                <Setter
                                                    Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush
                                                            EndPoint="1, .5"
                                                            StartPoint="0, .5">
                                                            <GradientStop
                                                                Color="#FFF3F2"
                                                                Offset=".3" />
                                                            <GradientStop
                                                                Color="White"
                                                                Offset=".9" />
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>

                                            <DataTrigger
                                                Binding="{Binding Type}"
                                                Value="Other">
                                                <Setter
                                                    Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush
                                                            EndPoint="1, .5"
                                                            StartPoint="0, .5">
                                                            <GradientStop
                                                                Color="#F0F0F0"
                                                                Offset=".3" />
                                                            <GradientStop
                                                                Color="White"
                                                                Offset=".9" />
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>

                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition
                                                        Binding="{Binding Type}"
                                                        Value="Information" />
                                                    <Condition
                                                        Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}"
                                                        Value="True" />
                                                </MultiDataTrigger.Conditions>

                                                <Setter
                                                    Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush
                                                            EndPoint="1, .5"
                                                            StartPoint="0, .5">
                                                            <GradientStop
                                                                Color="#DEF4FC"
                                                                Offset=".3" />
                                                            <GradientStop
                                                                Color="#ABEAFF"
                                                                Offset=".9" />
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter
                                                    Property="Effect"
                                                    Value="{StaticResource DefaultDropShadow}" />
                                            </MultiDataTrigger>

                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition
                                                        Binding="{Binding Type}"
                                                        Value="Warning" />
                                                    <Condition
                                                        Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}"
                                                        Value="True" />
                                                </MultiDataTrigger.Conditions>

                                                <Setter
                                                    Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush
                                                            EndPoint="1, .5"
                                                            StartPoint="0, .5">
                                                            <GradientStop
                                                                Color="#FAF9E8"
                                                                Offset=".3" />
                                                            <GradientStop
                                                                Color="#FCF7C0"
                                                                Offset=".9" />
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter
                                                    Property="Effect"
                                                    Value="{StaticResource DefaultDropShadow}" />
                                            </MultiDataTrigger>

                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition
                                                        Binding="{Binding Type}"
                                                        Value="Error" />
                                                    <Condition
                                                        Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}"
                                                        Value="True" />
                                                </MultiDataTrigger.Conditions>

                                                <Setter
                                                    Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush
                                                            EndPoint="1, .5"
                                                            StartPoint="0, .5">
                                                            <GradientStop
                                                                Color="#FFF3F2"
                                                                Offset=".3" />
                                                            <GradientStop
                                                                Color="#FFCBC7"
                                                                Offset=".9" />
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter
                                                    Property="Effect"
                                                    Value="{StaticResource DefaultDropShadow}" />
                                            </MultiDataTrigger>

                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition
                                                        Binding="{Binding Type}"
                                                        Value="Other" />
                                                    <Condition
                                                        Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}"
                                                        Value="True" />
                                                </MultiDataTrigger.Conditions>

                                                <Setter
                                                    Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush
                                                            EndPoint="1, .5"
                                                            StartPoint="0, .5">
                                                            <GradientStop
                                                                Color="#ECECEC"
                                                                Offset=".3" />
                                                            <GradientStop
                                                                Color="#E0E0E0"
                                                                Offset=".9" />
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter
                                                    Property="Effect"
                                                    Value="{StaticResource DefaultDropShadow}" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid
                                    Margin="0, 0, 0, 10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition
                                            Width="Auto" />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition
                                            Height="Auto" />
                                        <RowDefinition
                                            Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Grid.Row="0"
                                        Orientation="Horizontal">
                                        <Image
                                            Margin="0, 0, 5, 0"
                                            Source="{Binding ProcessIcon}" />
                                        <TextBlock
                                            FontSize="15"
                                            FontWeight="Bold"
                                            Margin="0, 0, 0, 5">
                                            <TextBlock.Text>
                                                <MultiBinding
                                                    StringFormat="{}{0} ({1})">
                                                    <Binding
                                                        Path="ProcessName" />
                                                    <Binding
                                                        Path="ProcessId" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock
                                            Text="{Binding Timestamp, StringFormat='{} (yyyy-MM-dd HH:mm:ss)'}" />
                                    </StackPanel>

                                    <Image
                                        Grid.Column="0"
                                        Grid.Row="1"
                                        Grid.RowSpan="2"
                                        Margin="0, 0, 10, 0"
                                        ToolTip="{Binding Type}">
                                        <Image.Style>
                                            <Style
                                                TargetType="Image">
                                                <Setter
                                                    Property="Source"
                                                    Value="../Resources/other.png" />

                                                <Style.Triggers>
                                                    <DataTrigger
                                                        Binding="{Binding Type}"
                                                        Value="Information">
                                                        <Setter
                                                            Property="Source"
                                                            Value="../Resources/info.png" />
                                                    </DataTrigger>

                                                    <DataTrigger
                                                        Binding="{Binding Type}"
                                                        Value="Warning">
                                                        <Setter
                                                            Property="Source"
                                                            Value="../Resources/warning.png" />
                                                    </DataTrigger>

                                                    <DataTrigger
                                                        Binding="{Binding Type}"
                                                        Value="Error">
                                                        <Setter
                                                            Property="Source"
                                                            Value="../Resources/error.png" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>

                                    <TextBlock
                                        Grid.Column="1"
                                        Grid.Row="1"
                                        FontWeight="DemiBold"
                                        Text="{Binding Title}" />

                                    <TextBlock
                                        Grid.Column="1"
                                        Grid.Row="2"
                                        Text="{Binding Message}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <Button
                Command="{Binding ClearDialogsCommand}"
                Content="Clear list"/>
            <CheckBox
                Content="Auto-scroll"
                IsChecked="{Binding AutoScroll}"
                Margin="20, 0, 0, 0" />
        </StackPanel>
    </Grid>
</Window>
